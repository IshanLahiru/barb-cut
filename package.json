{
  "name": "barb-cut-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "firebase"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:local": "turbo run dev:local --parallel",
    "start:local": "./scripts/start-local-dev.sh",
    "emulator:start": "turbo run emulator:start",
    "emulator:migrate": "turbo run emulator:migrate",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "setup:local": "npm run emulator:start && npm run emulator:migrate"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@react-native-firebase/app": "^23.8.4",
    "@react-native-firebase/auth": "^23.8.4",
    "@react-native-firebase/firestore": "^23.8.4",
    "@react-native-firebase/storage": "^23.8.4"
  }
}
